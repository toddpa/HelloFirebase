{
  "name": "hello-firebase",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --exclude src/access/firestore.rules.test.ts",
    "test:rules": "firebase emulators:exec --only firestore \"./node_modules/.bin/vitest run --environment node src/access/firestore.rules.test.ts\"",
    "test:watch": "vitest"
  },
  "dependencies": {
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^29.0.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.0",
    "vitest": "^4.1.0"
  }
}
